# Server
PORT=5000
NODE_ENV=production

# Database — use MongoDB Atlas for production
# Free tier: https://www.mongodb.com/cloud/atlas/register
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/aakali

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRE=7d

# Email (Gmail App Password — NOT your regular password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Aakali <noreply@aakali.in>

# Frontend URL (set to your Render domain after deploy)
FRONTEND_URL=https://aakali.onrender.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Razorpay — Live mode keys for production
# Get from: https://dashboard.razorpay.com → Live Mode → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_live_secret

# Razorpay Webhook Secret — must match Dashboard → Webhooks configuration
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Twilio (optional — for OTP login)
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
